<Window x:Class="ChatCLient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatCLient"
        mc:Ignorable="d"
        Title="Chat - Rooms" Height="450" Width="800">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- messages -->
        <ListBox Grid.Row="0" ItemsSource="{Binding Messages}"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border CornerRadius="4" Padding="6,3" Margin="0,2">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <!-- tint my own messages -->
                                    <DataTrigger Binding="{Binding Mine}" Value="True">
                                        <Setter Property="Background" Value="#E8F0FE"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock>
                                <Run Text="{Binding User}" FontWeight="Bold"/>
                                <Run Text="  "/>
                                <Run Text="{Binding SentAt, StringFormat=HH:mm}"
                                     Foreground="Gray" FontSize="11"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <ListBox Grid.Row="2" ItemsSource="{Binding Rooms}" DisplayMemberPath="Name"
         MouseDoubleClick="Rooms_MouseDoubleClick"/>
        <!-- status line -->
        <TextBlock Grid.Row="1" Text="{Binding Status}" Foreground="Gray" Margin="0,6,0,0"/>

        <!-- input row: type + Enter, or click Send -->
        <DockPanel Grid.Row="2" Margin="0,6,0,0">
            <Button DockPanel.Dock="Right" Content="Send" Width="72" Margin="8,0,0,0"
                    Command="{Binding SendCommand}"/>
            <TextBox Text="{Binding Draft, UpdateSourceTrigger=PropertyChanged}"
                     KeyDown="Draft_KeyDown"/>
        </DockPanel>
    </Grid>
</Window>
